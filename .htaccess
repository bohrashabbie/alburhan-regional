# Next.js Static Export - GoDaddy Shared Hosting Configuration
# Disable ETags completely to prevent caching issues
FileETag None

# Enable Rewrite Engine
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # CRITICAL: Redirect root URL (/) to /en/ - This must be first!
  RewriteCond %{REQUEST_URI} ^/$
  RewriteRule ^$ /en/ [R=301,L]

  # If file exists, serve it
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # If directory exists, serve it
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Add trailing slash to locale directories if missing
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_URI} ^/(en|ar)$
  RewriteRule ^(.*)$ /$1/ [R=301,L]

  # Handle locale-prefixed routes with trailing slashes
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} ^/(en|ar)/(.*)/$
  RewriteRule ^(en|ar)/(.*)/$ /$1/$2/index.html [L]

  # Handle locale-prefixed routes without trailing slashes
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} ^/(en|ar)/(.*)$
  RewriteRule ^(en|ar)/(.*)$ /$1/$2/index.html [L]

  # Redirect any other non-locale routes to /en/
  RewriteCond %{REQUEST_URI} !^/(en|ar)/
  RewriteCond %{REQUEST_URI} !^/$
  RewriteRule ^(.*)$ /en/$1 [R=301,L]
</IfModule>

# Enable compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Browser caching - Aggressive no-cache for HTML/CSS/JS during development
<IfModule mod_expires.c>
  ExpiresActive On
  # Images can be cached longer
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  # Very short cache for CSS/JS to ensure updates are reflected immediately
  ExpiresByType text/css "access plus 0 seconds"
  ExpiresByType application/javascript "access plus 0 seconds"
  ExpiresByType text/javascript "access plus 0 seconds"
  ExpiresByType application/json "access plus 0 seconds"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Cache-Control headers for better cache management
<IfModule mod_headers.c>
  # Security headers
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  
  # Disable ETags to prevent caching issues
  Header unset ETag
  
  # Cache control for HTML files - no cache (most important)
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
    Header unset ETag
  </FilesMatch>
  
  # Cache control for CSS/JS - no cache to ensure updates are reflected
  # Next.js already adds hashes to filenames, so we can be aggressive here
  <FilesMatch "\.(css|js|json)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
    Header unset ETag
  </FilesMatch>
  
  # Cache control for Next.js static assets (they have hashes in filenames)
  <FilesMatch "_next/static/">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  
  # Cache control for images - long cache (images rarely change)
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>


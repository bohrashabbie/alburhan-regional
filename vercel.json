{
  "buildCommand": "npm run build:vercel",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/",
      "destination": "/en"
    },
    {
      "source": "/:path((?!en|ar|_next|api|favicon.ico|.*\\..*).*)",
      "destination": "/en/:path"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
